<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="Join Live Class"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Select Your Subject"
        android:textColor="#555555"
        android:textSize="14sp" />

    <!-- Enrolled subjects dropdown -->
    <androidx.appcompat.widget.AppCompatSpinner
        android:id="@+id/spinnerEnrolledSubject"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_spinner"
        android:padding="4dp" />

    <!-- Shown when student has no enrollments -->
    <TextView
        android:id="@+id/textNotEnrolled"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="You are not enrolled in any subjects yet.\nGo to the Subjects tab to register."
        android:textColor="#F44336"
        android:textSize="13sp"
        android:visibility="gone" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutCode"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:hint="Enter 4-Letter Code">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editAttendanceCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapCharacters"
            android:letterSpacing="0.2"
            android:maxLength="4"
            android:maxLines="1"
            android:textAlignment="center"
            android:textSize="24sp"
            android:textStyle="bold" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnJoinSession"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Join Session"
        android:textAllCaps="false" />

</LinearLayout>
